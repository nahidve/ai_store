generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  VENDOR
  ADMIN
}

enum ProductType {
  INTERNAL
  EXTERNAL
}

enum ProductStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
}

enum ServiceStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
}

enum OrderStatus {
  PENDING
  PAID
  CANCELLED
  REFUNDED
}

enum ServiceOrderStatus {
  PENDING
  PAID
  ACCEPTED
  IN_PROGRESS
  DELIVERED
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  CREATED
  PAID
  FAILED
  REFUNDED
}

enum ExecutionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum MediaType {
  IMAGE
  VIDEO
}

model User {
  id           String @id @default(cuid())
  name         String
  email        String @unique
  passwordHash String

  role UserRole @default(USER)

  avatar String?

  isEmailVerified Boolean @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  sessions Session[]

  products Product[]
  services Service[]

  reviews Review[]

  productOrders ProductOrder[]
  serviceOrders ServiceOrder[]

  productPurchases ProductPurchase[]

  executions ProductExecution[]
}

model Session {
  id String @id @default(cuid())

  userId String

  expiresAt  DateTime
  lastUsedAt DateTime

  ipAddress String?
  userAgent String?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isActive])
  @@index([expiresAt])
}

model Category {
  id String @id @default(cuid())

  name String
  slug String @unique

  parentId String?

  parent Category? @relation("CategoryHierarchy", fields: [parentId], references: [id])

  children Category[] @relation("CategoryHierarchy")

  products Product[]
  services Service[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId])
}

model WorkflowTemplate {
  id String @id @default(cuid())

  name String
  slug String @unique

  description String

  systemPrompt String

  inputSchema  Json
  outputSchema Json

  isActive Boolean @default(true)

  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

model Product {
  id String @id @default(cuid())

  title String
  slug  String @unique

  shortDescription String
  description      String

  thumbnail String?

  priceInPaise Int

  productType ProductType

  status ProductStatus @default(DRAFT)

  websiteUrl String?
  demoUrl    String?

  vendorId String

  categoryId String

  workflowTemplateId String?

  vendor User @relation(fields: [vendorId], references: [id])

  category Category @relation(fields: [categoryId], references: [id])

  workflowTemplate WorkflowTemplate? @relation(fields: [workflowTemplateId], references: [id])

  media ProductMedia[]

  reviews Review[]

  orders ProductOrder[]

  purchases ProductPurchase[]

  executions ProductExecution[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([vendorId])
  @@index([categoryId])
  @@index([status])
}

model ProductMedia {
  id String @id @default(cuid())

  productId String

  url String

  type MediaType

  sortOrder Int @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([productId])
}

model Service {
  id String @id @default(cuid())

  title String
  slug  String @unique

  description String

  priceInPaise Int

  deliveryDays Int

  status ServiceStatus @default(DRAFT)

  vendorId String

  categoryId String

  vendor User @relation(fields: [vendorId], references: [id])

  category Category @relation(fields: [categoryId], references: [id])

  reviews Review[]

  orders ServiceOrder[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([vendorId])
  @@index([categoryId])
  @@index([status])
}

model ProductOrder {
  id String @id @default(cuid())

  buyerId String

  productId String

  amountInPaise Int

  status OrderStatus @default(PENDING)

  buyer User @relation(fields: [buyerId], references: [id])

  product Product @relation(fields: [productId], references: [id])

  payment Payment?

  purchase ProductPurchase?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([buyerId])
  @@index([productId])
  @@index([status])
}

model ServiceOrder {
  id String @id @default(cuid())

  buyerId String

  serviceId String

  amountInPaise Int

  status ServiceOrderStatus @default(PENDING)

  buyer User @relation(fields: [buyerId], references: [id])

  service Service @relation(fields: [serviceId], references: [id])

  payment Payment?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([buyerId])
  @@index([serviceId])
  @@index([status])
}

model Payment {
  id String @id @default(cuid())

  razorpayOrderId String @unique

  razorpayPaymentId String?

  amountInPaise Int

  status PaymentStatus

  productOrderId String? @unique

  serviceOrderId String? @unique

  productOrder ProductOrder? @relation(fields: [productOrderId], references: [id])

  serviceOrder ServiceOrder? @relation(fields: [serviceOrderId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

model ProductPurchase {
  id String @id @default(cuid())

  buyerId String

  productId String

  orderId String @unique

  buyer User @relation(fields: [buyerId], references: [id])

  product Product @relation(fields: [productId], references: [id])

  order ProductOrder @relation(fields: [orderId], references: [id])

  createdAt DateTime @default(now())

  @@unique([buyerId, productId])
  @@index([buyerId])
  @@index([productId])
}

model Review {
  id String @id @default(cuid())

  userId String

  productId String?

  serviceId String?

  rating Int

  comment String

  user User @relation(fields: [userId], references: [id])

  product Product? @relation(fields: [productId], references: [id])

  service Service? @relation(fields: [serviceId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId])
  @@unique([userId, serviceId])
  @@index([userId])
  @@index([productId])
  @@index([serviceId])
}

model ProductExecution {
  id String @id @default(cuid())

  userId String

  productId String

  status ExecutionStatus @default(PENDING)

  input Json

  output Json?

  error String?

  tokensUsed Int?

  user User @relation(fields: [userId], references: [id])

  product Product @relation(fields: [productId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([productId])
  @@index([status])
  @@index([createdAt])
}
